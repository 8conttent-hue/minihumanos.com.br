---
// Hero-F: Glassmorphic Card - Design flutuante centralizado
interface Props {
  title: string;
  subtitle: string;
  btnText: string;
  btnLink: string;
  bgImage: string;
}
const { title, subtitle, btnText, btnLink, bgImage } = Astro.props;
---
<section class="relative min-h-screen flex items-center justify-center p-4 md:p-8">
  <!-- Bg Image com Overlay -->
  <div class="absolute inset-0 z-0">
    <img src={bgImage} class="w-full h-full object-cover" alt="Background" />
    <div class="absolute inset-0 bg-dark/40 backdrop-grayscale-[0.5]"></div>
  </div>

  <!-- Content Card -->
  <div class="relative z-10 w-full max-w-4xl bg-white/10 backdrop-blur-xl border border-white/20 rounded-[2.5rem] p-8 md:p-16 lg:p-24 shadow-2xl text-center overflow-hidden group transition-all duration-700 hover:bg-white/[0.15]">
    
    <!-- Decorative Glow -->
    <div class="absolute -top-24 -left-24 w-64 h-64 bg-primary/30 rounded-full blur-[100px] opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>
    <div class="absolute -bottom-24 -right-24 w-64 h-64 bg-accent/30 rounded-full blur-[100px] opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>

    <div class="relative z-20">
      <span class="inline-block px-4 py-2 rounded-xl bg-white/10 text-white text-[10px] font-black uppercase tracking-[0.3em] mb-8 border border-white/10">
        Inovação & Cuidado
      </span>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-white leading-tight mb-8 drop-shadow-lg">
        {title}
      </h1>
      <p class="text-lg md:text-xl text-white/70 leading-relaxed mb-12 max-w-2xl mx-auto font-medium">
        {subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={btnLink}
          class="px-10 py-5 bg-white text-dark font-black rounded-2xl hover:scale-105 active:scale-95 transition-all shadow-xl shadow-white/10 flex items-center justify-center"
        >
          {btnText}
        </a>
        <a
          href="#mais"
          class="px-10 py-5 border border-white/20 text-white font-bold rounded-2xl hover:bg-white/10 transition-all flex items-center justify-center backdrop-blur-sm"
        >
          Saiba Mais
        </a>
      </div>
    </div>
  </div>
</section>